# Turso(SQLite 호환) 데이터베이스 접속 정보
# https://turso.tech 에서 무료 계정을 만들고 데이터베이스를 하나 생성하면
# `turso db show <db이름> --url` 로 URL을, `turso db tokens create <db이름>` 로
# 토큰을 얻을 수 있어요.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# 로그인 세션 쿠키에 서명할 때 쓰는 임의의 긴 문자열. 아무 값이나 충분히
# 길고 예측하기 어렵게 만들어 넣어주세요(예: openssl rand -hex 32).
AUTH_SECRET=

# 이 앱이 실제로 배포된 공개 URL(맨 끝에 / 없이). 이메일 인증·비밀번호
# 재설정 링크를 만들 때 사용해요. 로컬 개발에서는 비워두면
# http://localhost:3000 을 사용해요.
APP_URL=

# Resend(https://resend.com)에서 만든 API 키. 없으면 이메일 인증/비밀번호
# 재설정 메일이 실제로 발송되지 않고, 그 사실이 API 응답에 표시돼요.
RESEND_API_KEY=

# Resend에 인증된 발신 도메인/주소를 사용한 "발신자" 값
# (예: "봄이야, 밥 먹자! <noreply@yourdomain.com>").
EMAIL_FROM=

# Google Cloud Console(https://console.cloud.google.com) > API 및 서비스 >
# 사용자 인증 정보에서 만든 "OAuth 2.0 클라이언트 ID"의 클라이언트 ID/보안
# 비밀번호. 승인된 리디렉션 URI에 "{APP_URL}/api/auth/google/callback"을
# 반드시 등록해야 해요(로컬 개발 시 "http://localhost:3000/api/auth/google/callback").
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
